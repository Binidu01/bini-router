{
  "name": "bini-router",
  "version": "1.0.27",
  "description": "File-based routing, nested layouts, auto-imports, and Hono-powered API routes for Vite + React",
  "author": "bini.js",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "bini-env": "^1.0.6"
  },
  "peerDependencies": {
    "hono"              : ">=4.0.0",
    "vite"              : ">=7.0.0",
    "react"             : ">=18.0.0",
    "react-dom"         : ">=18.0.0",
    "react-router-dom"  : ">=6.0.0",
    "@hono/node-server" : ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "hono"             : { "optional": false },
    "vite"             : { "optional": false },
    "react"            : { "optional": false },
    "react-dom"        : { "optional": false },
    "react-router-dom" : { "optional": false },
    "@hono/node-server": { "optional": true }
  },
  "devDependencies": {
    "@types/node"         : "^25.3.5",
    "@types/react"        : "^19.2.14",
    "@types/react-dom"    : "^19.2.3",
    "@hono/node-server"   : "^1.14.4",
    "hono"                : "^4.12.5",
    "react"               : "^19.2.4",
    "react-dom"           : "^19.2.4",
    "react-router-dom"    : "^7.13.1",
    "tsup"                : "^8.5.1",
    "typescript"          : "^5.9.3",
    "vite"                : "^7.3.1"
  },
  "keywords": [
    "vite", "vite-plugin", "bini", "bini-js", "react",
    "hono", "file-based-routing", "routing", "api-routes", "layouts",
    "auto-import", "bini-env", "edge-functions", "netlify", "vercel",
    "cloudflare", "loading-screen", "metadata"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Binidu01/bini-router.git"
  },
  "homepage": "https://bini.js.org",
  "bugs": { "url": "https://github.com/Binidu01/bini-router/issues" },
  "engines": { "node": ">=18.0.0" }
}